                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('access_token', json.access_token);",
                  "if (json.accessToken) pm.collectionVariables.set('access_token', json.accessToken);",
                  "if (json.token) pm.collectionVariables.set('access_token', json.token);",
                  "if (json.refresh_token) pm.collectionVariables.set('refresh_token', json.refresh_token);",
                  "if (json.refreshToken) pm.collectionVariables.set('refresh_token', json.refreshToken);"
